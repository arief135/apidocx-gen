{
  "name": "apidocx-gen",
  "version": "1.0.0",
  "description": "Browser-based UI5 (TypeScript) app to author and export API references as DOCX.",
  "private": true,
  "scripts": {
    "start": "ui5 serve --open index.html",
    "build": "ui5 build --clean-dest --dest dist",
    "ts-typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@openui5/types": "~1.148.0",
    "@sap/ux-ui5-tooling": "^1.25.0",
    "@ui5/cli": "^4.0.33",
    "typescript": "^5.9.3",
    "ui5-tooling-transpile": "^3.10.0"
  }
}
