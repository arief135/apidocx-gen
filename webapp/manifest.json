{
  "_version": "1.60.0",
  "sap.app": {
    "id": "oneflux.apiref",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "title": "API Reference Builder",
    "description": "Author and export API references as DOCX, entirely in the browser.",
    "applicationVersion": { "version": "1.0.0" }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "oneflux.apiref.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.ui.core": {},
        "sap.m": {},
        "sap.tnt": {},
        "sap.ui.layout": {}
      }
    },
    "contentDensities": { "compact": true, "cozy": true },
    "models": {},
    "resources": {
      "css": [{ "uri": "css/style.css" }]
    }
  }
}
